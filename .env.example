# Copy to .env (which is gitignored) and fill in real values before running locally.
# In production, inject these as environment variables — never commit .env to git.

DB_URL=jdbc:postgresql://localhost:5432/sudokupro
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

REDIS_HOST=localhost
REDIS_PORT=6379

# Flyway owns the schema (db/migration); Hibernate only validates it.
# The dev profile uses "update" instead and disables Flyway for local iteration.
DDL_AUTO=validate

# Remove spring.security.user.* in production and provision accounts via the DB.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# ---- Push notifications (FCM HTTP v1, optional) ----
# Disabled by default. To enable: set FCM_ENABLED=true and point
# FCM_SERVICE_ACCOUNT_FILE at a Google service-account JSON key with the
# "Firebase Cloud Messaging API" enabled. Startup fails fast if enabled
# without a readable key file. Clients register their device tokens via
# POST /api/notifications/device-token.
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_FILE=

# ---- Desktop client (read by the JavaFX app, not the server) ----
# The client is a pure network client; these prefill the connect screen.
#SUDOKUPRO_SERVER=http://localhost:8080
#SUDOKUPRO_USER=admin
#SUDOKUPRO_PASS=
